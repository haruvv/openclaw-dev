---
export interface Props {
  url: string;
  title: string;
  description?: string;
  badge?: string;
}

const { url, title, description, badge } = Astro.props;
---

<div class="affiliate-link">
  {badge && <span class="affiliate-badge">{badge}</span>}
  <div class="affiliate-content">
    <h4 class="affiliate-title">{title}</h4>
    {description && <p class="affiliate-desc">{description}</p>}
  </div>
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer sponsored"
    class="affiliate-btn"
    data-tool-name={title}
    data-link-url={url}
    onclick="if(typeof gtag==='function'){gtag('event','affiliate_click',{tool_name:this.dataset.toolName,link_url:this.dataset.linkUrl})}"
  >
    詳細を見る &rarr;
  </a>
</div>

<style>
  .affiliate-link {
    background: var(--surface);
    border: 2px solid var(--primary);
    border-radius: var(--radius);
    padding: 1.25rem;
    position: relative;
    transition: box-shadow 0.2s;
  }
  .affiliate-link:hover {
    box-shadow: 0 4px 16px rgba(79, 70, 229, 0.15);
  }
  .affiliate-badge {
    position: absolute;
    top: -10px;
    left: 12px;
    background: linear-gradient(135deg, #f59e0b, #ef4444);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 100px;
  }
  .affiliate-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.4rem;
  }
  .affiliate-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  .affiliate-btn {
    display: inline-block;
    background: var(--primary);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .affiliate-btn:hover {
    background: var(--primary-dark);
    text-decoration: none;
    color: #fff;
  }
</style>
