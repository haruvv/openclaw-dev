---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RecommendedTools from '../../components/RecommendedTools.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateLink from '../../components/AffiliateLink.astro';
import { getToolsByCategory } from '../../data/recommended-tools';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const categoryLinks: Record<string, string> = {
  '開発ツール': '/categories/dev-tools',
  'ビジネス自動化': '/categories/business-automation',
  'SNS運用・マーケティング': '/categories/social-media',
  '教育・学習': '/categories/education',
  'ライフハック・生産性': '/categories/lifehack',
};

const categorySlugs: Record<string, string> = {
  '開発ツール': 'dev-tools',
  'ビジネス自動化': 'business-automation',
  'SNS運用・マーケティング': 'social-media',
  '教育・学習': 'education',
  'ライフハック・生産性': 'lifehack',
};

const categoryHref = categoryLinks[article.data.category] ?? '/';
const categorySlug = categorySlugs[article.data.category] ?? '';
const relatedTools = getToolsByCategory(categorySlug, 3);
---

<Base title={article.data.title} description={article.data.description}>
  <style>
    .breadcrumb { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }
    .breadcrumb a { color: var(--primary); }
    .article-header { margin-bottom: 2rem; }
    .category-badge {
      display: inline-block;
      background: var(--primary);
      color: #fff;
      font-size: 0.8rem;
      padding: 3px 12px;
      border-radius: 100px;
      margin-bottom: 1rem;
    }
    .article-header h1 { font-size: 1.8rem; font-weight: 800; line-height: 1.4; margin-bottom: 0.75rem; }
    .article-meta { font-size: 0.85rem; color: var(--text-muted); }
    .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem; }
    .tag {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 2px 10px;
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    .article-layout { display: grid; grid-template-columns: 1fr 280px; gap: 2rem; }
    @media (max-width: 800px) { .article-layout { grid-template-columns: 1fr; } }
    .article-body {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      margin-bottom: 2rem;
    }
    .article-body h2 { font-size: 1.3rem; font-weight: 700; margin: 2rem 0 0.75rem; padding-bottom: 0.4rem; border-bottom: 2px solid var(--border); }
    .article-body h3 { font-size: 1.1rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
    .article-body p { margin-bottom: 1rem; }
    .article-body ul, .article-body ol { padding-left: 1.5rem; margin-bottom: 1rem; }
    .article-body li { margin-bottom: 0.3rem; }
    .article-body blockquote {
      border-left: 4px solid var(--primary);
      padding: 0.5rem 1rem;
      background: #f1f5f9;
      border-radius: 0 var(--radius) var(--radius) 0;
      margin: 1rem 0;
      color: var(--text-muted);
    }
    .article-body code {
      background: #f1f5f9;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.9em;
      font-family: 'Consolas', 'Monaco', monospace;
    }
    .article-body pre {
      background: #1e293b;
      color: #e2e8f0;
      padding: 1rem;
      border-radius: var(--radius);
      overflow-x: auto;
      margin: 1rem 0;
    }
    .article-body pre code { background: none; padding: 0; color: inherit; }
    .related-tools {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      margin-bottom: 2rem;
    }
    .related-tools h2 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--primary);
    }
    .related-tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1rem;
    }
    .back-link { margin-top: 2rem; }
    .article-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
  </style>

  <nav class="breadcrumb">
    <a href="/">ホーム</a> &rsaquo;
    <a href={categoryHref}>{article.data.category}</a> &rsaquo;
    {article.data.title}
  </nav>

  <div class="article-header">
    <span class="category-badge">{article.data.category}</span>
    <h1>{article.data.title}</h1>
    <div class="article-meta">
      公開日: {article.data.pubDate.toLocaleDateString('ja-JP')}
    </div>
    {article.data.tags && article.data.tags.length > 0 && (
      <div class="tags">
        {article.data.tags.map(tag => <span class="tag">#{tag}</span>)}
      </div>
    )}
  </div>

  <div class="article-layout">
    <div>
      <div class="article-body">
        <Content />
      </div>

      <AdSlot slot="in-article" />

      {relatedTools.length > 0 && (
        <div class="related-tools">
          <h2>この記事で紹介したツール</h2>
          <div class="related-tools-grid">
            {relatedTools.map(tool => (
              <AffiliateLink
                url={tool.url}
                title={tool.title}
                description={tool.description}
                badge={tool.badge}
              />
            ))}
          </div>
        </div>
      )}

      <div class="back-link">
        <a href={categoryHref}>&larr; {article.data.category}の記事一覧へ</a>
      </div>
    </div>

    <aside class="article-sidebar">
      <RecommendedTools tools={relatedTools} heading={`${article.data.category}のおすすめツール`} />
      <AdSlot slot="sidebar" />
      <AdSlot slot="mobile" />
    </aside>
  </div>
</Base>
